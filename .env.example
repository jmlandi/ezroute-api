# Server Configuration
# Port the API server will listen on
PORT=3001
# Node environment (development, staging, production)
NODE_ENV=development

# Database Configuration
# PostgreSQL connection string - format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ezroute?schema=public

# Cache Configuration
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Authentication
# JWT secret token for signing authentication tokens
JWT_TOKEN=your_jwt_secret_token_here

# External Services - Analytics
# Amplitude API key for event tracking
AMPLITUDE_API_KEY=your_amplitude_api_key

# External Services - CRM
# Braze API key for user identification and lifecycle messaging
BRAZE_API_KEY=your_braze_api_key

# External Services - Email
# Resend API key for transactional email sending
RESEND_API_KEY=your_resend_api_key

# Cassandra Configuration
# Cassandra contact points (nodes to connect to)
CASSANDRA_CONTACT_POINTS=localhost
# Cassandra data center name
CASSANDRA_DATA_CENTER=datacenter1
# Cassandra keyspace name
CASSANDRA_KEYSPACE=ezroute
